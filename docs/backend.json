
{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "Producto del menú con soporte para modificadores e inventario.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "category": { "type": "string" },
        "modifiers": { "type": "array", "items": { "type": "string" } },
        "tpvColor": { "type": "string" },
        "tpvShape": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Perfil de cliente para sistema de lealtad.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "points": { "type": "number" },
        "totalVisits": { "type": "number" },
        "lastVisit": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["draft", "open", "confirmed", "paid"] },
        "serviceType": { "type": "string", "enum": ["mesa", "llevar", "domicilio", "rappi", "ubereats", "didifood"] },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "customerId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/menu/{itemId}": { "schema": "MenuItem" },
    "/customers/{customerId}": { "schema": "Customer" },
    "/orders/{orderId}": { "schema": "Order" },
    "/tickets/{ticketId}": { "schema": "KitchenTicket" }
  }
}

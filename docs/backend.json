
{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "Un producto disponible en el menú con detalles de inventario y TPV.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "category": { "type": "string" },
        "categoryId": { "type": "string" },
        "image": { "type": "string" },
        "soldBy": { "type": "string", "enum": ["unidad", "peso"] },
        "reference": { "type": "string" },
        "barcode": { "type": "string" },
        "trackInventory": { "type": "boolean" },
        "inventoryCount": { "type": "number" },
        "tpvColor": { "type": "string" },
        "tpvShape": { "type": "string", "enum": ["cuadrado", "circulo", "hexágono"] },
        "modifiers": { "type": "array" }
      },
      "required": ["name", "price", "soldBy", "trackInventory"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" }
      }
    },
    "Modifier": {
      "title": "Modifier",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "options": { "type": "array" }
      }
    },
    "Discount": {
      "title": "Discount",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "number" },
        "type": { "type": "string", "enum": ["porcentaje", "monto"] }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["draft", "confirmed", "paid"] },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paidAmount": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/menu/{itemId}": { "schema": "MenuItem" },
    "/categories/{catId}": { "schema": "Category" },
    "/modifiers/{modId}": { "schema": "Modifier" },
    "/discounts/{discId}": { "schema": "Discount" },
    "/orders/{orderId}": { "schema": "Order" },
    "/tickets/{ticketId}": { "schema": "KitchenTicket" }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA GLOBAL DE DESARROLLO:
    // Permite lectura y escritura a CUALQUIER documento si el usuario está autenticado.
    // Esto evita errores de permisos en estructuras multi-tenant complejas.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
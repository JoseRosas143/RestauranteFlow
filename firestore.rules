
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global para el prototipo: permite todo a usuarios autenticados
    // Actualizado: 2024-05-20 para asegurar propagación
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para la estructura de RestauranteFlow
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /orgs/{orgId} {
      allow read, write: if request.auth != null;
      
      match /{allSubPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}

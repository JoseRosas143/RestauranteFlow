
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global definitiva para desarrollo: 
    // Cualquier usuario autenticado tiene permiso total sobre cualquier documento o colección.
    // Esto resuelve los errores de "list" y "update" en rutas profundas como /orgs/{id}/locations/{id}/orders
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

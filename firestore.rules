
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES HELPER ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica acceso a la organización
    // Para prototipado, permitimos acceso si el usuario está autenticado. 
    // En producción se validaría la relación usuario -> orgId.
    function isOrgMember(orgId) {
      return isSignedIn();
    }

    // --- REGLAS DE COLECCIÓN ---

    match /users/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /orgs/{orgId} {
      allow read, write: if isOrgMember(orgId);

      match /users/{userId} {
        allow read, write: if isOrgMember(orgId);
      }

      match /customers/{customerId} {
        allow read, write: if isOrgMember(orgId);
      }

      match /settings/{settingId} {
        allow read, write: if isOrgMember(orgId);
      }

      match /locations/{locId} {
        allow read, write: if isOrgMember(orgId);

        match /menuItems/{itemId} { allow read, write: if isOrgMember(orgId); }
        match /categories/{catId} { allow read, write: if isOrgMember(orgId); }
        match /modifiers/{modId} { allow read, write: if isOrgMember(orgId); }
        match /discounts/{discId} { allow read, write: if isOrgMember(orgId); }
        match /orders/{orderId} { allow read, write: if isOrgMember(orgId); }
        match /kitchenTickets/{ticketId} { allow read, write: if isOrgMember(orgId); }
        
        match /analytics/{path=**} {
          allow read, write: if isOrgMember(orgId);
        }
      }
    }

    match /tickets/{ticketId} {
      allow read, write: if isSignedIn();
    }
  }
}

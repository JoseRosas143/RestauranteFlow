
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla de acceso universal para el prototipo: 
    // Cualquier usuario autenticado puede leer y escribir en cualquier documento.
    // Esto garantiza que la estructura multi-tenant (/orgs/...) funcione sin bloqueos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regla específica para mayor seguridad en la estructura de organizaciones
    match /orgs/{orgId} {
      allow read, write: if request.auth != null;
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Perfiles de usuario
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla maestra para el prototipo: permite lectura y escritura total
    // a cualquier usuario que haya iniciado sesión correctamente.
    // Esto resuelve los errores de "Missing or insufficient permissions" 
    // en rutas multi-tenant como /orgs/{orgId}/locations/{locId}/...
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

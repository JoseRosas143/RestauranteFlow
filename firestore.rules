rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla global: permite lectura y escritura a cualquier documento si el usuario está autenticado.
    // Esto asegura que las operaciones multi-tenant no sean bloqueadas por reglas restrictivas durante el desarrollo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
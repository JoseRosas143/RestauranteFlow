
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas recursivas para la estructura de organizaciones y sucursales
    match /orgs/{orgId} {
      allow read, write: if request.auth != null;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Regla de respaldo para desarrollo
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla de acceso universal para el prototipo: 
    // Cualquier usuario autenticado tiene permiso total de lectura y escritura.
    // Esto previene errores de "Missing or insufficient permissions" en entornos de desarrollo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

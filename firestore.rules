
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES HELPER ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGLAS DE COLECCIÓN ---
    // Flexibilizadas para asegurar que el prototipo pueda escribir datos iniciales

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /orgs/{orgId} {
      // Permitimos lectura y escritura a cualquier usuario autenticado por ahora
      // para facilitar el onboarding multi-tenant
      allow read, write: if isSignedIn();

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /tickets/{ticketId} {
      allow read, write: if isSignedIn();
    }
    
    // Regla general de respaldo
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
